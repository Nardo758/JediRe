# JediRe User Agent - Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost/jedire_agent

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_AI_GATEWAY_ENABLED=false  # Set to true when we have access

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Authentication
JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Business
MARKUP_PERCENTAGE=30  # 30% margin over LLM costs

# App
DEBUG=true
HOST=0.0.0.0
PORT=8000
