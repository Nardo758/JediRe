    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run src/components/deal/sections/__tests__/V2FullAnalysis.errorBoundary.test.tsx",
    "deploy:check": "npm run lint:hooks && npm run lint && npm run test:ci && npm run build"
  },
  "overrides": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17"
  },
