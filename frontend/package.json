    "lucide-react": "^0.563.0",
    "mapbox-gl": "^3.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
