run = "bash run.sh"
entrypoint = "run.sh"
modules = ["nodejs-20", "python-3.12", "bash", "web", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["orbiton"]

[deployment]
run = ["node", "index.js"]
deploymentTarget = "cloudrun"
build = ["npm", "run", "build"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 4000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 23637
externalPort = 3003

[[ports]]
localPort = 23638
externalPort = 3002

[[ports]]
localPort = 23639
externalPort = 5000

[[ports]]
localPort = 23640
externalPort = 6000

[[ports]]
localPort = 23641
externalPort = 4200

[[ports]]
localPort = 23642
externalPort = 5173

[[ports]]
localPort = 23643
externalPort = 6800

[[ports]]
localPort = 23644
externalPort = 8000

[[ports]]
localPort = 23645
externalPort = 8008

[[ports]]
localPort = 23646
externalPort = 8081

[[ports]]
localPort = 23647
externalPort = 8080

[[ports]]
localPort = 23648
externalPort = 8099

[[ports]]
localPort = 23649
externalPort = 9000

[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "JediRe"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Inngest Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "agent-runtime-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Georgia DeKalb+Fulton Ingest"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Georgia Gwinnett+DeKalb Ingest"

[[workflows.workflow]]
name = "JediRe"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
isCanvasWorkflow = true

[[workflows.workflow]]
name = "Inngest Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx --yes inngest-cli@latest dev -u http://localhost:4000/api/inngest --no-discovery -p 8099"

[[workflows.workflow]]
name = "agent-runtime-tests"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm test -- --reporter=verbose src/agents/runtime/__tests__/"

[[workflows.workflow]]
name = "Georgia DeKalb+Fulton Ingest"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Superseded by Georgia Gwinnett+DeKalb Ingest workflow. Run: cd backend && npx ts-node --transpile-only scripts/enrich-georgia-comps.ts --county=DeKalb,Fulton'"

[[workflows.workflow]]
name = "Georgia Gwinnett+DeKalb Ingest"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx ts-node --transpile-only scripts/enrich-georgia-comps.ts --county=Gwinnett,DeKalb 2>&1 | tee /tmp/gwinnett-dekalb-ingest.log"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.production]
PORT = "5000"
NODE_ENV = "production"

[userenv.shared]
API_KEY_ADMIN = "8acb8b8cf3704e3af9c8bb8738925d103f7cda59b14d6c99d825cf29cfa195cb"
CLOUDFLARE_ACCOUNT_ID = "4c198a3635afafa443be6ef8e9717bb5"
FRED_API_KEY = "3eb93d0b7de899f90865b8794c9850f1"
STRIPE_PRICE_SCOUT_MONTHLY = "price_1TPB0HLfOO4b6Db2rObDXE7y"
STRIPE_PRICE_OPERATOR_MONTHLY = "price_1TPB0HLfOO4b6Db2ZR6KOS9K"
STRIPE_PRICE_PRINCIPAL_MONTHLY = "price_1TPB0ILfOO4b6Db2xIGkiYmC"
EMAIL_FROM = "JediRe <noreply@jedire.com>"
ARCHIVE_INGEST_SECRET = "jedire-archive-2026"
USE_NEW_PROPERTY_SCHEMA_VALUATION_COMPS = "shadow"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
