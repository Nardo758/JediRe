run = "bash run.sh"
entrypoint = "run.sh"
modules = ["nodejs-20", "python-3.12", "bash", "web", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["nano"]

[deployment]
run = ["node", "backend/dist/index.replit.js"]
deploymentTarget = "autoscale"
build = ["bash", "build.sh"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 4000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "JediRe"

[[workflows.workflow]]
name = "JediRe"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./start.sh"
waitForPort = 5000

[userenv]

[userenv.production]
PORT = "5000"
NODE_ENV = "production"

[userenv.shared]
API_KEY_ADMIN = "8acb8b8cf3704e3af9c8bb8738925d103f7cda59b14d6c99d825cf29cfa195cb"
CLOUDFLARE_ACCOUNT_ID = "4c198a3635afafa443be6ef8e9717bb5"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
