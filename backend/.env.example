# Server Configuration
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/jedire
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jedire
DB_USER=postgres
DB_PASSWORD=your_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration (for caching & sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Gmail Sync OAuth (Web application client — separate from auth login)
GOOGLE_GMAIL_CALLBACK_URL=http://localhost:4000/api/v1/gmail/callback

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-token
REGRID_API_KEY=your-regrid-api-key
CLAUDE_API_KEY=

# DeepSeek API (10x cheaper than Claude for execution tasks)
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-anthropic-claude-api-key

# Rent Scraper — SerpAPI for property website discovery
SERP_API_KEY=your-serpapi-key

# Rent Scraper — Cloudflare Browser Rendering for AI extraction
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_BR_TOKEN=your-cloudflare-browser-rendering-api-token

# WebSocket Configuration
WS_CORS_ORIGIN=http://localhost:3000
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/jedire.log

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenClaw Notifier — multi-channel out-of-band notifications.
# Comma-separated list of channels to enable. Leave blank to auto-enable any
# channel that has its credentials set. Example: "telegram,twilio".
OPENCLAW_ENABLED_CHANNELS=
# Channels that receive 5xx error notifications. Default is "telegram" only
# (SMS for every 500 is noisy). Set to blank to fan out to every enabled channel.
OPENCLAW_ERROR_CHANNELS=telegram
# Public base URL used to build deep links inside notifications (no trailing slash).
JEDIRE_PUBLIC_URL=http://localhost:3000

# OpenClaw — Telegram channel
# Bot token from @BotFather. Required to enable Telegram notifications.
TELEGRAM_BOT_TOKEN=
# Chat id (user or group) that receives notifications. Use @get_id_bot to find yours.
TELEGRAM_NOTIFY_CHAT_ID=
# Comma-separated chat ids permitted to invoke action buttons. If blank,
# only TELEGRAM_NOTIFY_CHAT_ID is allowed.
TELEGRAM_ALLOWED_CHAT_IDS=
# (RECOMMENDED in production) Random secret token. When set, JediRe enforces
# the X-Telegram-Bot-Api-Secret-Token header on action callback requests so
# attackers can't forge button taps. Pass the SAME value as `secret_token` in
# your setWebhook call: curl ".../setWebhook?url=...&secret_token=<value>".
TELEGRAM_WEBHOOK_SECRET=

# OpenClaw — Twilio channel (WhatsApp / iMessage / SMS)
# Account SID + auth token from twilio.com/console. The auth token also
# enables X-Twilio-Signature verification on inbound action commands.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number in E.164 (e.g. +14155550100) or a "whatsapp:+...." sender.
TWILIO_FROM_PHONE_NUMBER=
# Comma-separated recipient numbers (E.164) for outbound notifications.
TWILIO_NOTIFY_TO_NUMBERS=
# Comma-separated numbers permitted to invoke action commands ("approve abc123").
# If blank, the TWILIO_NOTIFY_TO_NUMBERS list is treated as the allowlist.
TWILIO_ALLOWED_NUMBERS=
# Optional: override the URL Twilio signs when the request goes through a
# reverse proxy that rewrites Host. Example: "https://api.jedire.com".
TWILIO_WEBHOOK_BASE_URL=

# Legacy ClawdBot REST API (separate from the OpenClaw notifier above).
# These two are still used by /api/v1/clawdbot/{command,query,health} for
# inbound webhook authentication and by oppgrid.routes.ts as a token fallback.
CLAWDBOT_WEBHOOK_SECRET=your-webhook-secret-change-this
CLAWDBOT_AUTH_TOKEN=your-auth-token-change-this

# News API Providers (JediRe-held keys, users pay credits)
# The Guardian (FREE - 5000 calls/day, full content)
GUARDIAN_API_KEY=your-guardian-api-key
# NYT (FREE - 500 calls/day, headlines only)
NYT_API_KEY=your-nyt-api-key
# NewsAPI.org (FREE 100/day or $449/mo commercial)
NEWSAPI_KEY=your-newsapi-key
