{
  "version": "1.0.0",
  "lastUpdated": "2026-04-13",
  "mappings": {
    "mf_core": {
      "label": "MF Core",
      "primaryProduct": "agency_fixed",
      "primaryProductLabel": "Agency Long-Term Fixed (Fannie DUS / Freddie Conventional)",
      "alternatives": ["cmbs_10yr", "life_co"],
      "structure": {
        "termYears": 10,
        "amortYears": 30,
        "ioMonths": 24,
        "targetLtv": 0.70,
        "maxLtv": 0.75,
        "rateType": "Fixed",
        "recourse": "non-recourse",
        "origFee": 0.010,
        "prepayType": "yield_maintenance"
      },
      "rationale": "Core multifamily stabilized assets underwrite best for agency (Fannie/Freddie). Non-recourse, long-term fixed rates, and supplemental potential make agency the clear primary.",
      "keywords": ["core", "stabilized", "multifamily"]
    },
    "mf_core_plus": {
      "label": "MF Core-Plus",
      "primaryProduct": "agency_supplemental",
      "primaryProductLabel": "Agency with Supplemental Allowance",
      "alternatives": ["cmbs_10yr", "portfolio_bank"],
      "structure": {
        "termYears": 10,
        "amortYears": 30,
        "ioMonths": 36,
        "targetLtv": 0.725,
        "maxLtv": 0.75,
        "rateType": "Fixed",
        "recourse": "non-recourse",
        "origFee": 0.010,
        "prepayType": "yield_maintenance",
        "supplementalEligibleMonths": 36
      },
      "rationale": "Core-plus assets benefit from agency execution with supplemental loan capacity in Y3-5 to fund light value-add capex without a full refi.",
      "keywords": ["core plus", "light value", "minor renovation"]
    },
    "mf_value_add": {
      "label": "MF Value-Add",
      "primaryProduct": "bridge_to_perm",
      "primaryProductLabel": "Bridge-to-Perm (Bridge 2-3yr → Agency Refi at Stabilization)",
      "alternatives": ["debt_fund_fixed"],
      "structure": {
        "phase1": {
          "product": "bridge",
          "termYears": 3,
          "extensions": "2 × 1yr",
          "ioMonths": 36,
          "targetLtc": 0.70,
          "maxLtc": 0.75,
          "rateType": "Floating",
          "spread": 0.0275,
          "origFee": 0.015,
          "exitFee": 0.005,
          "prepayType": "open",
          "recourse": "non-recourse"
        },
        "phase2": {
          "product": "agency",
          "triggerOcc": 0.92,
          "triggerDscr": 1.35,
          "triggerMonth": 24,
          "termYears": 10,
          "amortYears": 30,
          "ioMonths": 24,
          "targetLtv": 0.65,
          "maxLtv": 0.75,
          "rateType": "Fixed",
          "prepayType": "yield_maintenance"
        }
      },
      "rationale": "Value-add properties need bridge flexibility during renovation (IO, draws, no immediate DSCR test), then permanent fixed-rate agency financing at stabilization to lock in long-term capital.",
      "keywords": ["value add", "value-add", "renovation", "reposition", "rehab", "rental_value_add"]
    },
    "mf_deep_value_add": {
      "label": "MF Deep Value-Add",
      "primaryProduct": "bridge_mezz_stack",
      "primaryProductLabel": "Bridge + Mezz Stack",
      "alternatives": ["pref_equity_sub"],
      "structure": {
        "seniorLtc": 0.70,
        "mezzLtc": 0.80,
        "mezzRate": 0.13,
        "mezzPik": true,
        "termYears": 3,
        "ioMonths": 36,
        "rateType": "Floating"
      },
      "rationale": "Deep value-add requires higher leverage to fund heavy capex. Senior bridge to 70% LTC + mezz to 80-85% LTC achieves the capital needed. Mezz at 12-14% pay + PIK.",
      "keywords": ["deep value", "heavy renovation", "gut rehab"]
    },
    "mf_distressed": {
      "label": "MF Distressed",
      "primaryProduct": "private_credit",
      "primaryProductLabel": "Private Credit / Distressed Bridge",
      "alternatives": ["note_purchase"],
      "structure": {
        "termYears": 2,
        "ioMonths": 24,
        "targetLtc": 0.65,
        "rateType": "Floating",
        "spread": 0.0450,
        "recourse": "partial",
        "prepayType": "open"
      },
      "rationale": "Distressed assets carry performance and covenant risk that conventional lenders won't underwrite. Private credit accepts the risk premium in exchange for higher pricing and partial recourse.",
      "keywords": ["distressed", "foreclosure", "note", "npl"]
    },
    "mf_lease_up": {
      "label": "MF Lease-Up",
      "primaryProduct": "bridge_earnout",
      "primaryProductLabel": "Bridge-to-Perm with Earnout",
      "alternatives": ["agency_lease_up_program"],
      "structure": {
        "termYears": 3,
        "ioMonths": 36,
        "targetLtc": 0.70,
        "rateType": "Floating",
        "spread": 0.0300,
        "earnoutMilestoneOcc": 0.90,
        "earnoutMilestoneDscr": 1.25
      },
      "rationale": "Lease-up assets fund at partial proceeds initially; earnout provisions release remaining proceeds as occupancy and DSCR milestones are met, reducing initial lender risk.",
      "keywords": ["lease up", "lease-up", "new construction stabilizing", "c/o"]
    },
    "mf_ground_up": {
      "label": "MF BTS Ground-Up",
      "primaryProduct": "construction_to_perm",
      "primaryProductLabel": "Construction Loan → Bridge-to-Perm or Sale",
      "alternatives": ["hud_221d4"],
      "structure": {
        "phase1": {
          "product": "construction",
          "termMonths": 36,
          "ioMonths": 36,
          "targetLtc": 0.70,
          "maxLtc": 0.75,
          "rateType": "Floating",
          "interestReserve": true
        },
        "phase2": {
          "product": "bridge_or_agency",
          "triggerMonth": 36,
          "decision": "refi_or_sell"
        }
      },
      "rationale": "Ground-up construction requires a construction loan with interest reserve and draw schedule. At certificate of occupancy, the exit is typically a refi to permanent or sale at stabilization.",
      "keywords": ["ground up", "ground-up", "new construction", "build to sell", "build_to_sell", "bts"]
    },
