        "concessions",
        "vacancy"
      ],
      "isDefault": false,
      "appropriateFor": [
        "value_add",
        "redevelopment"
      ]
    },
    "gpr_minus_loss_to_lease": {
      "id": "gpr_minus_loss_to_lease",
      "label": "GPR − Loss-to-Lease",
      "description": "Top-down: gross potential rent reduced by an explicit loss-to-lease percentage.",
      "inputs": [
