        "behaviour": "use as-is"
      },
      "yellow": {
        "minConfidence": 0.45,
        "behaviour": "use with warning banner"
      },
      "red": {
        "minConfidence": 0,
        "behaviour": "reject — surface \"missing\" until upgraded"
      }
    },
    "refusalThreshold": 0.45
